# caches / toolchain (huge, machine-local, regenerable)
.cache/
__pycache__/

# per-run artifacts (regenerable; transcripts published separately)
runs/

# generated, deterministic from fixtures/generate_fixtures.py (seed-pinned)
fixtures/out/
fixtures/truth/

# results DB: the live one is regenerated by a campaign; backups are local
results.sqlite
results.sqlite.*
*.sqlite-wal
*.sqlite-shm

# generated leaderboard output
leaderboard.md

# logs (campaign / calibration / rep run logs)
*.log

# tokenade local project state
.tokenade/

# agent-instruction files (tokenade auto-scaffolds these; excluded so a
# benchmark that ranks tokenade ships none of its own agent rules)
CLAUDE.md
AGENTS.md
.cursorrules
.cursor/
.claude/
.github/copilot-instructions.md
# older tokenade-injected agent-rule snapshots
*.original.md

# tokenade-internal improvement reports (not impartial benchmark output)
reports/

.DS_Store

# redundant copy of docs/data/results.json (canonical for the site)
/results.json
