# caches / toolchain (huge, machine-local, regenerable)
.cache/
__pycache__/

# per-run artifacts (regenerable; transcripts published separately)
runs/

# generated, deterministic from fixtures/generate_fixtures.py (seed-pinned)
fixtures/out/
fixtures/truth/

# results DB: published as the dataset of record. Backups stay local.
results.sqlite.*
*.sqlite-wal
*.sqlite-shm

# generated leaderboard output
leaderboard.md

# logs (campaign / calibration / rep run logs)
*.log

# tokenade local project state
.tokenade/

# agent-instruction files (tokenade auto-scaffolds these; excluded so a
# benchmark that ranks tokenade ships none of its own agent rules)
CLAUDE.md
AGENTS.md
.cursorrules
.cursor/
.claude/
.github/copilot-instructions.md
# older tokenade-injected agent-rule snapshots
*.original.md

# tokenade-internal improvement reports (not impartial benchmark output)
reports/

.DS_Store

# redundant copy of docs/data/results.json (canonical for the site)
/results.json
# Added by code-review-graph
.code-review-graph/

# QA artifacts
.playwright-mcp/
*-page-check.png

# generated research dataset (derived from transcripts; rebuild with research/build_dataset.py)
research/dataset/

# tokenade — legacy per-project embedding model cache (now global)
.fastembed_cache/

# trivially-short tasks (control <5 turns avg) — kept locally, excluded from the public board
_excluded_tasks/

# tokenade-internal R&D arms + research — kept locally, off the public board
_excluded_internal/
competitors/tokenade-*/

# working notes and one-off scripts — kept locally
AUDIT-*.md
BENCH_PROTOCOL_*.md
EDGEE-FINDINGS.md
run_codegraph_after.sh
runs_stale_prebinfix/

# Pages deploy workflow needs a workflow-scoped token to push; use branch-deploy instead (Settings > Pages > /docs). Kept in _excluded_internal/.
.github/workflows/
.claude-pin/
